# Server config — contains real IPs and model config
servers.json

# Workflow artifacts (state, backups, logs)
.workflow/state.json
.workflow/session.log
.workflow/backups/
.workflow/*.tmp

# Benchmark output files
benchmark_results_*

# Docker Compose env (contains secrets)
docker-compose.env

# Generated self-signed TLS certs for local HTTPS
certs/
