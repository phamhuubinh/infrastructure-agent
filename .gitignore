# Benchmark history (auto-generated, environment-specific)
.benchmark_history.json

# UI dependencies
ui/node_modules/
ui/dist/

# Local secrets (credentials, API tokens)
config/secrets.local.json

# Tool config with secrets removed — never commit token/url here
