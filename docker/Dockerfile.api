FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    wait-for-it \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[web]" 2>/dev/null || true

COPY src/ src/
COPY targets.json .
COPY servers.json .
COPY config/ config/

EXPOSE 61888

CMD ["uvicorn", "src.backend.api:app", "--host", "0.0.0.0", "--port", "61888"]
