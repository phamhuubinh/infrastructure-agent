FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    wait-for-it \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir -e ".[web]"

COPY targets.json .

# Generate a default servers.json for environments that don't supply it
RUN printf '{"active_server":"local","servers":{"local":{"provider":"openai","base_url":"http://localhost:8000","model":"gpt-4","timeout":300}}}\n' > /app/servers.json

EXPOSE 61888

CMD ["uvicorn", "src.backend.api:app", "--host", "0.0.0.0", "--port", "61888"]
